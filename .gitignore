# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js
/.npm-cache

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log
debug*.log
dev*.log
dev*.pid
.cursor/debug*.log
.tmp/

# local env files
.env*.local
.env

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# admin runtime data (keep templates/examples tracked)
data/admin/uploads/*
!data/admin/uploads/.gitkeep
data/admin/clients/*
!data/admin/clients/.gitkeep
data/admin/contracts/generated/*
!data/admin/contracts/generated/.gitkeep
data/admin/store/*
!data/admin/store/.gitkeep
